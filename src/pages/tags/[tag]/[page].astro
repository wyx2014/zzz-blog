---
import type { GetStaticPaths } from 'astro';
import Layout from '../../../layouts/Layout.astro';
import Card from '../../../components/Card.astro';
import { getCollection } from 'astro:content';

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection('blog', ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  });

  // Get unique tags
  const uniqueTags = [...new Set(allPosts.flatMap((post) => post.data.tags))];

  // Generate paths for each tag with pagination
  return uniqueTags.flatMap((tag) => {
    const tagPosts = allPosts
      .filter((post) => post.data.tags.includes(tag))
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

    return paginate(tagPosts, {
      params: { tag },
      pageSize: 5,
    });
  });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const { tag } = Astro.params;
---

<Layout 
  title={`标签 #${tag} 下的文章 - 第 ${page.currentPage} 页 | WYX's Journal`}
  description={`浏览本博客包含标签 #${tag} 的文章列表，当前第 ${page.currentPage} 页。`}
>
  <div class="flex flex-col space-y-8">
    <!-- Header Title -->
    <div class="border-b border-border-base pb-6">
      <span class="text-xs font-semibold uppercase tracking-wider text-accent-base">Tag Archive</span>
      <h1 class="font-serif text-3xl font-bold tracking-tight text-text-base md:text-4xl mt-2 flex items-center">
        <span class="text-accent-base/50 mr-2 select-none">#</span> {tag}
      </h1>
      <p class="text-sm text-text-muted mt-2">
        包含该标签的文章共有 {page.total} 篇。当前第 {page.currentPage} / {page.lastPage} 页。
      </p>
    </div>

    <!-- Tagged Articles List -->
    <div class="flex flex-col">
      {page.data.map((post) => (
        <Card 
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={post.id.replace(/\.[^/.]+$/, "")}
          tags={post.data.tags}
        />
      ))}
    </div>

    <!-- Beautiful Minimalist Pagination Navigation -->
    {page.lastPage > 1 && (
      <nav class="flex items-center justify-between border-t border-border-base/60 pt-6 text-sm font-medium" aria-label="Tag Pagination Navigation">
        <!-- Previous Page Button -->
        <div class="flex flex-1 justify-start">
          {page.url.prev ? (
            <a
              href={page.url.prev}
              class="inline-flex items-center space-x-1 py-2 text-text-muted hover:text-accent-base transition-colors group"
            >
              <svg class="h-4 w-4 transform transition-transform group-hover:-translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
              </svg>
              <span>上一页</span>
            </a>
          ) : (
            <span class="inline-flex items-center space-x-1 py-2 text-border-base cursor-not-allowed select-none">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
              </svg>
              <span>上一页</span>
            </span>
          )}
        </div>

        <!-- Page Indicator -->
        <span class="text-xs text-text-muted select-none">
          第 {page.currentPage} 页，共 {page.lastPage} 页
        </span>

        <!-- Next Page Button -->
        <div class="flex flex-1 justify-end">
          {page.url.next ? (
            <a
              href={page.url.next}
              class="inline-flex items-center space-x-1 py-2 text-text-muted hover:text-accent-base transition-colors group"
            >
              <span>下一页</span>
              <svg class="h-4 w-4 transform transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          ) : (
            <span class="inline-flex items-center space-x-1 py-2 text-border-base cursor-not-allowed select-none">
              <span>下一页</span>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </span>
          )}
        </div>
      </nav>
    )}
  </div>
</Layout>
