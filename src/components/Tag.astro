---
interface Props {
  name: string;
}

const { name } = Astro.props;
---

<a
  href={`/tags/${name}/1`}
  class="inline-flex items-center rounded-full border border-border-base bg-code-bg px-2.5 py-0.5 text-xs font-medium text-text-muted hover:border-accent-base hover:text-accent-base transition-all duration-200"
>
  <span class="text-accent-base/50 mr-1 select-none">#</span>
  {name}
</a>
