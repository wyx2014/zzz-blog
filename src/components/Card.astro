---
import FormattedDate from './FormattedDate.astro';
import Tag from './Tag.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags: string[];
}

const { title, description, pubDate, slug, tags } = Astro.props;
---

<article class="group relative flex flex-col items-start border-b border-border-base/60 py-8 last:border-b-0 animate-fade-in transition-all duration-300">
  <div class="flex w-full flex-col justify-between md:flex-row md:items-baseline gap-2">
    <!-- Post Title -->
    <h3 class="font-serif text-xl font-semibold tracking-tight text-text-base md:text-2xl">
      <a href={`/posts/${slug}`} class="relative block py-1">
        <span class="relative z-10 transition-colors duration-300 group-hover:text-accent-base">
          {title}
        </span>
        <span class="absolute bottom-0 left-0 h-[1.5px] w-0 bg-accent-base transition-all duration-300 group-hover:w-full"></span>
      </a>
    </h3>

    <!-- Post Date -->
    <div class="text-xs text-text-muted shrink-0">
      <FormattedDate date={pubDate} />
    </div>
  </div>

  <!-- Post Description -->
  <p class="mt-3 text-sm leading-relaxed text-text-muted md:text-base max-w-3xl">
    {description}
  </p>

  <!-- Tags & Read More -->
  <div class="mt-4 flex w-full flex-wrap items-center justify-between gap-3 text-xs">
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <Tag name={tag} />
      ))}
    </div>

    <a 
      href={`/posts/${slug}`} 
      class="flex items-center space-x-1 text-sm font-medium text-accent-base hover:text-accent-hover transition-colors group/link"
      aria-label={`阅读《${title}》`}
    >
      <span>阅读全文</span>
      <svg class="h-3.5 w-3.5 transform transition-transform group-hover/link:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
      </svg>
    </a>
  </div>
</article>
